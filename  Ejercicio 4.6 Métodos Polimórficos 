      "source": [
        "class Profesor:\n",
        "    def imprimir(self):\n",
        "        print(\"Es un Profesor\")\n",
        "\n",
        "\n",
        "class ProfesorTitular(Profesor):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.anos = 0\n",
        "\n",
        "    def imprimir(self):\n",
        "        print(\"Es un Profesor Titular\")\n",
        "\n",
        "    def imprimirAnos(self):\n",
        "        print(f\"Años = {self.anos}\")\n",
        "\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "\n",
        "    lista_profesores = [Profesor(), ProfesorTitular()]\n",
        "\n",
        "\n",
        "    for prof in lista_profesores:\n",
        "        prof.imprimir()\n",
        "\n",
        "\n",
        "        if hasattr(prof, 'imprimirAnos'):\n",
        "            prof.imprimirAnos()\n",
        "\n",
        "\n",
        "        print(\"===============\")\n",
        "        print()"
      ]
