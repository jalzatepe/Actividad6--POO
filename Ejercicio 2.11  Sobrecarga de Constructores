            "Título del artículo = La teoría especial de la relatividad\n",
            "Autor del artículo = Albert Einstein\n",
            "Palabras clave = \n",
            " - Física\n",
            " - Espacio\n",
            " - Tiempo\n",
            "Publicación = Anales de Física\n",
            "Año = 1913\n",
            "Resumen = Las leyes de la física son las mismas en todos los sistemas de referencia inerciales.\n"
          ]
        }
      ],
      "source": [
        "class ArticuloCientifico:\n",
        "\n",
        "\n",
        "    def __init__(self, titulo, autor, palabrasClaves=None, publicacion=None, ano=0, resumen=None):\n",
        "\n",
        "\n",
        "        self.titulo = titulo\n",
        "        self.autor = autor\n",
        "\n",
        "\n",
        "        if palabrasClaves is None:\n",
        "            self.palabrasClaves = []\n",
        "        else:\n",
        "            self.palabrasClaves = palabrasClaves\n",
        "\n",
        "        self.publicacion = publicacion\n",
        "        self.ano = ano\n",
        "\n",
        "\n",
        "        self.resumen = resumen\n",
        "\n",
        "    def imprimir(self):\n",
        "\n",
        "        print(f\"Título del artículo = {self.titulo}\")\n",
        "        print(f\"Autor del artículo = {self.autor}\")\n",
        "        print(\"Palabras clave = \")\n",
        "\n",
        "\n",
        "        for palabra in self.palabrasClaves:\n",
        "            print(f\" - {palabra}\")\n",
        "\n",
        "        print(f\"Publicación = {self.publicacion}\")\n",
        "        print(f\"Año = {self.ano}\")\n",
        "        print(f\"Resumen = {self.resumen}\")\n",
        "\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    palabras = [\"Física\", \"Espacio\", \"Tiempo\"]\n",
        "\n",
        "\n",
        "    articulo = ArticuloCientifico(\n",
        "        titulo=\"La teoría especial de la relatividad\",\n",
        "        autor=\"Albert Einstein\",\n",
        "        palabrasClaves=palabras,\n",
        "        publicacion=\"Anales de Física\",\n",
        "        ano=1913,\n",
        "        resumen=\"Las leyes de la física son las mismas en todos los sistemas de referencia inerciales.\"\n",
        "    )\n",
        "\n",
        "\n",
        "    articulo.imprimir()"
      ]
