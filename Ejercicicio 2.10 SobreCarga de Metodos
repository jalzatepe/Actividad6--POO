      "source": [
        "class Pedido:\n",
        "\n",
        "    def calcularPedido(self, primerPlato, costoPrimerPlato, bebida, costoBebida,\n",
        "                       segundoPlato=None, costoSegundoPlato=0.0,\n",
        "                       postre=None, costoPostre=0.0):\n",
        "\n",
        "\n",
        "        total = costoPrimerPlato + costoBebida + costoSegundoPlato + costoPostre\n",
        "\n",
        "\n",
        "        if segundoPlato is not None and postre is not None:\n",
        "\n",
        "            print(f\"El costo de {primerPlato} + {segundoPlato} + {bebida} + {postre} es = ${total:.2f}\")\n",
        "        elif segundoPlato is not None:\n",
        "\n",
        "            print(f\"El costo de {primerPlato} + {segundoPlato} + {bebida} es = ${total:.2f}\")\n",
        "        else:\n",
        "\n",
        "            print(f\"El costo de {primerPlato} y {bebida} es = ${total:.2f}\")\n",
        "\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "\n",
        "    pedido1 = Pedido()\n",
        "    pedido1.calcularPedido(\"Sancocho\", 5000, \"Gaseosa\", 2000)\n",
        "\n",
        "\n",
        "    pedido2 = Pedido()\n",
        "    pedido2.calcularPedido(\"Crema de verduras\", 5000, \"Gaseosa\", 2000, segundoPlato=\"Churrasco\", costoSegundoPlato=6000)\n",
        "\n",
        "\n",
