        "    pedido3.calcularPedido(\"Crema de espinacas\", 5000, \"Gaseosa\", 2000, segundoPlato=\"Salmón\", costoSegundoPlato=10000, postre=\"Tiramisú\", costoPostre=5000)"
      ]
